SERVER_NAME=example.com
LETSENCRYPT_EMAIL=admin@example.com
BACKEND_UPSTREAM=backend:8080
FRONTEND_UPSTREAM=frontend:80

POSTGRES_DB=shuknow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me

JWT_KEY=replace-with-long-random-secret
JWT_ISSUER=shuknow
JWT_AUDIENCE=shuknow
JWT_EXPIRES_IN_MINUTES=60
ENCRYPTION_KEY=replace-with-long-random-secret

BLOB_PROVIDER=S3
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET_NAME=shuknow
RUSTFS_PREFIX=blobs

BACKEND_IMAGE=ghcr.io/barmingeorge/shuknow:latest
FRONTEND_IMAGE=ghcr.io/barmingeorge/shuknow-frontend:latest

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
