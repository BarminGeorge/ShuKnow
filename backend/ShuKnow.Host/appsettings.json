{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "BlobStorage": {
        "Provider": "FileSystem",
        "FileSystem": {
            "BasePath": "./data/blobs"
        },
        "OrphanCleanup": {
            "IntervalHours": 6,
            "GracePeriodMinutes": 60
        }
    },
    "AuthCookie": {
        "Name": "token",
        "HttpOnly": true,
        "Secure": true,
        "IsEssential": true,
        "SameSite": "None",
        "MaxAgeMinutes": 60
    },
    "Metrics": {
        "RetrievalWindow": "30.00:00:00",
        "RetentionWeekStart": "7.00:00:00",
        "RetentionWeekEnd": "14.00:00:00"
    },
    "ChatSessions": {
      "Cleanup": {
        "IntervalMinutes": 30,
        "MaxAgeMinutes": 60
      }
    },
    "ForwardedHeaders": {
      "ForwardLimit": 1,
      "KnownProxies": [],
      "KnownNetworks": []
    },
    "TornadoAi": {
      "SystemPromptPath": null,
      "Temperature": 0.3,
      "MaxTurns": 50
  }
}
