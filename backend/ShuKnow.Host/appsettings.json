{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "BlobStorage": {
        "Provider": "FileSystem",
        "FileSystem": {
            "BasePath": "./data/blobs"
        },
        "OrphanCleanup": {
            "IntervalHours": 6,
            "GracePeriodMinutes": 60
        }
    },
    "AuthCookie": {
        "Name": "token",
        "HttpOnly": true,
        "Secure": true,
        "IsEssential": true,
        "SameSite": "None",
        "MaxAgeMinutes": 60
    },
    "ForwardedHeaders": {
      "ForwardLimit": 1,
      "KnownProxies": [],
      "KnownNetworks": []
  },
    "TornadoAi": {
        "Temperature": 0.3,
        "MaxTurns": 10
    }
}
